GAME_AVATAR_RENDER_BASE_URL=/api/game
GAME_AVATAR_CATALOG_CACHE_MS=10000

# Redis
ATTEMPT_REDIS_URL=redis://default:change-me@localhost:6379/0
GAME_REDIS_URL=redis://default:change-me@localhost:6379/0

