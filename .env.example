CLASS_KAFKA_GROUP=class-svc.v1
QUIZ_KAFKA_CLIENT_ID=quiz-service
QUIZ_KAFKA_GROUP=quiz-svc.v1
GAME_KAFKA_CLIENT_ID=game-service
GAME_KAFKA_GROUP=game-svc.v1
