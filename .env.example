QUIZ_MONGODB_URI=mongodb://change-me:change-me@localhost:27019/quiz?replicaSet=rs0&authSource=admin&retryWrites=true&w=majority
CLASS_MONGODB_URI=mongodb://change-me:change-me@localhost:27017/class?replicaSet=rs0&authSource=admin&retryWrites=true&w=majority
AI_MONGODB_URI=mongodb://change-me:change-me@localhost:27020/ai-service?replicaSet=rs0&authSource=admin&retryWrites=true&w=majority
GAME_MONGODB_URI=mongodb://change-me:change-me@localhost:27021/game?replicaSet=rs0&authSource=admin&retryWrites=true&w=majority

# Environment
ENV=PROD

# Upload URLs
